SELECT c.character_id, c.first_name, c.last_name, c.occupation,
       a.apartment_id, a.building_address, a.apartment_number, a.monthly_rent
       FROM characters c
       LEFT JOIN 
       apartments a on c.character_id = a.current_tenant_id
       
       UNION
       
       SELECT c.character_id, c.first_name, c.last_name, c.occupation,
       a.apartment_id, a.building_address, a.apartment_number, a.monthly_rent
       FROM apartments a
       LEFT JOIN 
       characters c on c.character_id = a.current_tenant_id;

