-- Return all customer and their related order 
SELECT c.customer_id, c.customer_name, o.order_id, o.total_amount, o.order_date FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id;

-- Return all customer whose order is null 
SELECT c.customer_id, c.customer_name, o.order_id, o.total_amount, o.order_date FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
WHERE o.order_id is null;

-- Returns the number of orders per customer
SELECT  c.customer_name, COUNT(o.order_id), IFNULL(SUM(o.total_amount),0) AS order_count FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
GROUP BY c.customer_id;

CREATE TABLE shipping(
shipping_id INT PRIMARY KEY,
order_id INT,
shipping_date DATE,
carrier VARCHAR(50),
tracking_number VARCHAR(50),
FOREIGN KEY (order_id) REFERENCES orders (order_id)
);

